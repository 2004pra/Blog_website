      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "  pm.environment.set('jwtToken', jsonData.token);",
              "}",
              "if (jsonData.user && jsonData.user.id) {",
              "  pm.environment.set('userId', jsonData.user.id);",
              "}"
            ]
          }
        }
      ]
